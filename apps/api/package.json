{
  "name": "@warchest/api",
  "version": "0.1.0",
  "private": true,
  "description": "WARCHEST API — Fastify + Prisma + Redis. Server-authoritative economy, battle validation, $WAR claims.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "worker": "tsx src/worker.ts",
    "setup:devnet": "tsx src/setup-devnet.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.3",
    "@types/web-push": "^3.6.4",
    "@warchest/db": "workspace:*",
    "@warchest/game-core": "workspace:*",
    "bs58": "^6.0.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.2",
    "tweetnacl": "^1.0.3",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}

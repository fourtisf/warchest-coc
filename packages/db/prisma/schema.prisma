// WARCHEST data model — build spec §Data model, refined.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  wallet    String?   @unique
  /// chosen commander name (3-16 chars, set before first entry)
  name      String?
  /// referrer user id (rewarded when this account wins its first raid)
  refBy     String?
  createdAt DateTime  @default(now())
  banned    Boolean   @default(false)
  isAdmin   Boolean   @default(false)
  /// salted hash of the last seen client IP — multi-account heuristics only
  ipHash    String?
  village   Village?
  pushSubs  PushSub[]
  clanMember ClanMember?
  chatMsgs  ChatMessage[]
  clanRequests ClanRequest[]
  ledger    WarLedger[]
  claims    Claim[]
  attacks   Battle[]  @relation("attacker")
  defenses  Battle[]  @relation("defender")
  seasons   SeasonScore[]
}

model Village {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gold          Float      @default(350)
  mana          Float      @default(350)
  war           Int        @default(40)
  trophies      Int        @default(10)
  /// cached strength score (villagePower) — clan power sums these
  power         Int        @default(0)
  buildersTotal Int        @default(2)
  shieldUntil   DateTime?
  lastSeen      DateTime   @default(now())
  createdAt     DateTime   @default(now())
  /// quest/progress counters (trained, wins, raids, gCollected, ... tTypes)
  statJson      Json       @default("{}")
  /// daily war chest
  lastDailyAt   DateTime?
  dailyStreak   Int        @default(0)
  /// obstacle respawn clock
  lastObstAt    DateTime?
  /// troops+spells consumed in the last resolved raid ("retrain" preset)
  lastArmyJson  Json?
  buildings     Building[]
  obstacles     Obstacle[]
  army          Army?
  trainJobs     TrainJob[]
  questStates   QuestState[]

  @@index([trophies])
}

model Building {
  id        Int       @id @default(autoincrement())
  villageId String
  village   Village   @relation(fields: [villageId], references: [id], onDelete: Cascade)
  type      String
  level     Int       @default(1)
  gx        Int
  gy        Int
  /// mine/well on-site storage at `storedAt` (production accrues lazily from there)
  storedFloat Float   @default(0)
  storedAt  DateTime  @default(now())
  /// under construction/upgrade until this moment
  busyUntil DateTime?
  jobKind   String?   // 'new' | 'up'
  jobTotalS Float?    // job length in seconds, for progress bars

  @@index([villageId])
}

model Obstacle {
  id        Int     @id @default(autoincrement())
  villageId String
  village   Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
  kind      String  // 'tree' | 'rock'
  gx        Int
  gy        Int
  cleared   Boolean @default(false)
  /// a builder is clearing it until this moment
  clearUntil  DateTime?
  clearTotalS Float?

  @@index([villageId])
}

model Army {
  villageId String  @id
  village   Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
  raider    Int     @default(0)
  sniper    Int     @default(0)
  bomber    Int     @default(0)
  imp       Int     @default(0)
  bruiser   Int     @default(0)
  warlock   Int     @default(0)
  gargoyle  Int     @default(0)
  mender    Int     @default(0)
  dragon    Int     @default(0)
  /// brewed battle spells (heal / rage / bolt / freeze)
  spellHeal Int     @default(0)
  spellRage Int     @default(0)
  spellBolt Int     @default(0)
  spellFreeze Int   @default(0)
  /// War Lab research levels per troop, e.g. {"raider":3}
  levelsJson Json   @default("{}")
  /// active research (one at a time, like the lab in CoC)
  researchTroop  String?
  researchUntil  DateTime?
  researchTotalS Float?
}

model Clan {
  id        String       @id @default(cuid())
  name      String       @unique
  desc      String       @default("")
  /// badge emoji index (client picks the glyph)
  badge     Int          @default(0)
  leaderId  String
  createdAt DateTime     @default(now())
  /// clan-war lifecycle: idle | searching | war
  warState  String       @default("idle")
  /// the active war, while warState = "war"
  warId     String?
  members   ClanMember[]
  messages  ChatMessage[]
  requests  ClanRequest[]
}

/// A clan-vs-clan war: fixed rosters, 2 attacks per member, best-per-defender stars.
model War {
  id          String      @id @default(cuid())
  clanAId     String
  clanBId     String
  /// denormalized names (survive clan renames/disbands for history)
  nameA       String
  nameB       String
  status      String      @default("active") // active | ended
  startsAt    DateTime    @default(now())
  endsAt      DateTime
  /// participants per side, snapshotted at declaration: [{uid,name,power}]
  rosterAJson Json
  rosterBJson Json
  starsA      Int         @default(0)
  starsB      Int         @default(0)
  /// average best destruction % per enemy base (tiebreaker)
  pctA        Float       @default(0)
  pctB        Float       @default(0)
  winner      String?     // clan id | "tie"
  attacks     WarAttack[]

  @@index([status, endsAt])
  @@index([clanAId, startsAt])
  @@index([clanBId, startsAt])
}

model WarAttack {
  id         Int      @id @default(autoincrement())
  warId      String
  war        War      @relation(fields: [warId], references: [id], onDelete: Cascade)
  attackerId String
  defenderId String
  stars      Int
  pct        Float
  createdAt  DateTime @default(now())

  @@index([warId, attackerId])
}

/// Daily aid totals (resource donations) — multi-account funneling caps.
model AidDay {
  userId   String
  /// UTC day key, "YYYY-MM-DD"
  day      String
  given    Int    @default(0)
  received Int    @default(0)

  @@id([userId, day])
}

/// CoC-style aid request: one open ask per member, filled by clanmates.
model ClanRequest {
  id         Int      @id @default(autoincrement())
  clanId     String
  clan       Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       String   // 'troops' | 'gold' | 'mana'
  /// troops: housing space asked; gold/mana: amount asked
  amount     Int
  filled     Int      @default(0)
  /// compact donation log for display: [{n: donorName, t: "🪓×2"}]
  donorsJson Json     @default("[]")
  status     String   @default("open") // open | done | cancelled
  createdAt  DateTime @default(now())

  @@index([clanId, status])
  @@index([userId, createdAt])
}

model ClanMember {
  userId   String   @id
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clanId   String
  clan     Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade)
  role     String   @default("member") // leader | member
  joinedAt DateTime @default(now())

  @@index([clanId])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  /// null = global channel
  clanId    String?
  clan      Clan?    @relation(fields: [clanId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([clanId, id])
}

model PushSub {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  failCount Int      @default(0)

  @@index([userId])
}

model TrainJob {
  id         Int      @id @default(autoincrement())
  villageId  String
  village    Village  @relation(fields: [villageId], references: [id], onDelete: Cascade)
  troopType  String
  /// set when the job reaches the head of the queue; null while waiting
  finishesAt DateTime?
  totalS     Float

  @@index([villageId])
}

model QuestState {
  villageId String
  village   Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
  questId   String
  done      Boolean @default(false)
  doneAt    DateTime?

  @@id([villageId, questId])
}

model Battle {
  id                   String   @id @default(cuid())
  attackerId           String
  attacker             User     @relation("attacker", fields: [attackerId], references: [id])
  defenderId           String?
  defender             User?    @relation("defender", fields: [defenderId], references: [id])
  /// SimBuilding[] + th + pool at scout time
  defenderSnapshotJson Json
  seed                 Int
  deployLogJson        Json?
  stars                Int      @default(0)
  pct                  Float    @default(0)
  lootG                Int      @default(0)
  lootM                Int      @default(0)
  warEarned            Int      @default(0)
  trophyDelta          Int      @default(0)
  status               String   @default("scouted") // scouted | resolved | expired | aborted
  validated            Boolean  @default(false)
  seenByDefender       Boolean  @default(false)
  createdAt            DateTime @default(now())
  resolvedAt           DateTime?

  /// defender has used their revenge for this raid
  revenged             Boolean  @default(false)
  /// attacker troop research levels at resolve time (replay determinism)
  levelsJson           Json?
  /// set when this battle is a clan-war attack (no loot/trophies/shield)
  warId                String?

  @@index([attackerId, status])
  @@index([defenderId, resolvedAt])
}

model WarLedger {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  delta     Int
  reason    String   // quest | raid | spend | claim | obstacle | admin
  refId     String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Claim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int
  fee       Int
  wallet    String
  txSig     String?
  status    String   @default("pending") // pending | sent | confirmed | failed
  attempts  Int      @default(0)
  error     String?
  createdAt DateTime @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
}

model Season {
  id       String        @id @default(cuid())
  startsAt DateTime
  endsAt   DateTime
  scores   SeasonScore[]
}

model SeasonScore {
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  trophies Int    @default(0)

  @@id([seasonId, userId])
  @@index([seasonId, trophies])
}
